<odoo>
    <record id="catalog_extension_product_template_form_view" model="ir.ui.view">
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group" position="after">
                <group string="Catalog Extension"> 
                    <group>
                        <field name="badge_label"/>
                        <field name="warranty_months"/>
                    </group>
                    <group>
                        <field name="product_origin"/>
                        <field name="is_promo_active"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>